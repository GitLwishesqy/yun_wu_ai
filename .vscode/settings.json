{
    // ==================== TODO Tree 配置 ====================
    "todo-tree.general.tags": [
        "TODO",
        "FIXME",
        "HACK",
        "BUG",
        "OPTIMIZE",
        "NOTE",
        "REVIEW",
        "XXX",
        "WARN",
        "[ ]",
        "[x]"
    ],

    "todo-tree.highlights.defaultHighlight": {
        "icon": "circle-slash",
        "type": "text-and-comment",
        "foreground": "#7D8A80",
        "background": "#F2F5F3",
        "opacity": 50,
        "iconColour": "#7D8A80"
    },

    "todo-tree.highlights.customHighlight": {
        "TODO": {
            "icon": "checklist",
            "type": "text-and-comment",
            "foreground": "#FFFFFF",
            "background": "#F0A858",
            "iconColour": "#F0A858",
            "gutterIcon": true,
            "fontWeight": "bold"
        },
        "FIXME": {
            "icon": "flame",
            "type": "text-and-comment",
            "foreground": "#FFFFFF",
            "background": "#E8837A",
            "iconColour": "#E8837A",
            "gutterIcon": true,
            "fontWeight": "bold"
        },
        "BUG": {
            "icon": "bug",
            "type": "text-and-comment",
            "foreground": "#FFFFFF",
            "background": "#E8837A",
            "iconColour": "#E8837A",
            "gutterIcon": true
        },
        "HACK": {
            "icon": "tools",
            "type": "text-and-comment",
            "foreground": "#FFFFFF",
            "background": "#D0D8D2",
            "iconColour": "#D0D8D2"
        },
        "OPTIMIZE": {
            "icon": "rocket",
            "type": "text-and-comment",
            "foreground": "#222E27",
            "background": "#A8D8EA",
            "iconColour": "#A8D8EA"
        },
        "NOTE": {
            "icon": "info",
            "type": "text-and-comment",
            "foreground": "#222E27",
            "background": "#A8D8EA",
            "iconColour": "#68B8D8"
        },
        "REVIEW": {
            "icon": "eye",
            "type": "text-and-comment",
            "foreground": "#FFFFFF",
            "background": "#7EB8D4",
            "iconColour": "#7EB8D4"
        },
        "XXX": {
            "icon": "alert",
            "type": "text-and-comment",
            "foreground": "#FFFFFF",
            "background": "#E8837A",
            "iconColour": "#E8837A"
        },
        "WARN": {
            "icon": "warning",
            "type": "text-and-comment",
            "foreground": "#222E27",
            "background": "#F5C26B",
            "iconColour": "#F5C26B"
        },
        "[ ]": {
            "icon": "circle-outline",
            "type": "text-and-comment",
            "foreground": "#7D8A80",
            "background": "#F2F5F3"
        },
        "[x]": {
            "icon": "check",
            "type": "text-and-comment",
            "foreground": "#6BBF7A",
            "background": "#D4EDDA",
            "iconColour": "#6BBF7A"
        }
    },

    "todo-tree.regex.regex": "((//|#|<!--|;|/\\*|\\*|--|\\*\\*)\\s*($TAGS)|^\\s*- \\[ \\])",
    "todo-tree.regex.regexCaseSensitive": false,

    "todo-tree.filtering.includeHiddenFiles": false,

    "todo-tree.filtering.excludeGlobs": [
        "**/node_modules/**",
        "**/target/**",
        "**/.git/**",
        "**/dist/**",
        "**/build/**",
        "**/out/**",
        "**/*.class",
        "**/*.jar",
        "**/*.png",
        "**/*.jpg",
        "**/*.gif",
        "**/*.svg",
        "**/*.mp3",
        "**/*.mp4",
        "**/*.pdf"
    ],

    "todo-tree.filtering.includeGlobs": [
        "**/*.java",
        "**/*.xml",
        "**/*.sql",
        "**/*.md",
        "**/*.yml",
        "**/*.yaml",
        "**/*.properties",
        "**/*.js",
        "**/*.ts",
        "**/*.tsx",
        "**/*.jsx",
        "**/*.css",
        "**/*.html",
        "**/*.json",
        "**/*.py"
    ],

    "todo-tree.general.statusBar": "total",
    "todo-tree.general.statusBarClickAction": "reveal",
    "todo-tree.general.showTagsFromOpenFilesOnly": false,
    "todo-tree.general.enableFileWatcher": true,

    "todo-tree.tree.autoRefresh": true,
    "todo-tree.tree.scanMode": "workspace",
    "todo-tree.tree.expanded": true,
    "todo-tree.tree.hideIconsWhenGrouped": false,
    "todo-tree.tree.flat": false,
    "todo-tree.tree.grouped": true,
    "todo-tree.tree.groupBy": "tag",
    "todo-tree.tree.sort": "line",
    "todo-tree.tree.tooltipFormat": "${file} : ${line}",
    "todo-tree.tree.showCountsInTree": true,
    "todo-tree.tree.showBadges": true,

    "todo-tree.tree.labelFormat": "${line} ${after}",
    "todo-tree.tree.disableCompactFolders": true,

    // ==================== 编辑器配置 ====================
    "editor.rulers": [120],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.renderWhitespace": "boundary",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.minimap.enabled": false,
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.fontLigatures": true,

    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/target": true,
        "**/.idea": true,
        "**/*.class": true
    },
    "files.watcherExclude": {
        "**/target/**": true,
        "**/node_modules/**": true
    },

    "search.exclude": {
        "**/target": true,
        "**/node_modules": true,
        "**/.git": true
    },

    // ==================== Java 配置 ====================
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-21",
            "path": "D:/huanjingpeizhi/Java"
        }
    ],
    "java.compile.nullAnalysis.mode": "automatic",
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.format.settings.url": ".vscode/java-formatter.xml",
    "java.format.settings.profile": "YunWu",
    "java.import.gradle.enabled": false,
    "java.autobuild.enabled": true,
    "java.server.launchMode": "Standard",
    "java.inlayHints.parameterNames.enabled": "literals",

    "java.references.includeAccessors": true,
    "java.references.includeDecompiledSources": true,

    // ==================== 文件配置 ====================
    "files.autoSave": "onFocusChange",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,

    // ==================== 终端配置 ====================
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx4G -Xms100m -Xlog:disable"
}
