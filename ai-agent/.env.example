# 云悟英语 AI 智能体 — 环境变量配置

# LLM 配置
LLM_PROVIDER=openai              # openai / deepseek / qwen
LLM_MODEL=gpt-4o
LLM_API_KEY=f0856d59e4244461a17ae60b3e9abe1a.SBM7KetOTv6Rqeog
LLM_BASE_URL=                    # 留空使用默认，或填自定义 endpoint
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=30

# LLM 重试 (指数退避)
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_MIN_WAIT=1.0
LLM_RETRY_MAX_WAIT=10.0
LLM_RETRY_BACKOFF=2.0

# 服务配置
HOST=0.0.0.0
PORT=2668
DEBUG=false

# 安全配置
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30    # 每分钟请求数
RATE_LIMIT_BURST_SIZE=10             # 突发容量

# Redis (状态持久化 + 分布式限流)
REDIS_ENABLED=false                  # 生产环境设为 true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# 纠错开关
CORRECTION_ENABLED=true

# pgvector 向量数据库 (PostgreSQL)
PGVECTOR_ENABLED=false                        # 生产环境设为 true
PGVECTOR_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yunwu_english
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# 可观测性
LOG_LEVEL=INFO                       # DEBUG / INFO / WARNING
LOG_FORMAT=json                      # json / text
TRACING_ENABLED=true
