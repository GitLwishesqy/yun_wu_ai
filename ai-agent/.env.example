# 云悟英语 AI 智能体 — 环境变量配置

# LLM 配置
LLM_PROVIDER=openai          # openai / deepseek / qwen
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-xxxxxxxxxxxx
LLM_BASE_URL=                # 留空使用默认，或填自定义 endpoint
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 纠错开关
CORRECTION_ENABLED=true
